# Exemplo de ACL do Mosquitto para o device ESP32.
#
# Copie para /etc/mosquitto/acl.conf (caminho referenciado em
# mosquitto.conf.example) e ajuste os tópicos conforme o que o firmware
# realmente usa (ver MQTT_TCP_NOTIFY_TOPIC em main/app_main.c).
#
# "esp32-device-01" precisa bater com o CLIENT_CN usado em
# scripts/generate_certs.sh -- é o CN do certificado do device, usado como
# "usuário" graças a use_identity_as_username no mosquitto.conf.

user esp32-device-01

topic write device/tcp_server/client_connected

# Se no futuro o ESP32 também assinar algum tópico de comando/config,
# adicione explicitamente (o Mosquitto nega por padrão tudo que não está
# listado aqui, quando um acl_file está configurado):
# topic read device/tcp_server/cmd

# --- Exemplo de um segundo cliente mTLS (ex: uma app rodando no mesmo PC
# do broker, com certificado gerado via scripts/generate_client_cert.sh
# CLIENT_CN=pc-app-01) -- ela só LÊ o que o ESP32 publica, não publica nada:
# user pc-app-01
# topic read device/tcp_server/client_connected
